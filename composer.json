{
    "name": "gebruederheitz/wp-async-posts-provider",
    "description": "Helps you get your posts asynchronously to the frontend in your plugin or theme",
    "type": "library",
    "license": "GPL-3.0-only",
    "autoload": {
        "psr-4": {
            "Gebruederheitz\\WpAsyncPostsProvider\\": "Gebruederheitz/WpAsyncPostsProvider/"
        }
    },
    "authors": [
        {
            "name": "Andreas Maros",
            "email": "andreas.maros@gebruederheitz.de"
        }
    ],
    "require": {
        "php": ">=8.0",
        "php-di/php-di": "^7.1.1",
        "gebruederheitz/simple-singleton": "^v1.0.1",
        "gebruederheitz/wp-simple-rest": "^v3.0.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1.47",
        "szepeviktor/phpstan-wordpress": "^v2.0.3",
        "wecodemore/wpstarter": "~3.0.1",
        "johnpbloch/wordpress-core": "6.9.*@stable"
    },
    "scripts": {
        "lint": "phpstan --memory-limit=2G analyse -c .phpstan.neon"
    },
    "config": {
        "allow-plugins": {
            "johnpbloch/wordpress-core-installer": true,
            "composer/installers": true,
            "wecodemore/wpstarter": true
        }
    },
    "extra": {
        "wordpress-content-dir": ".wp/wordpress/wp-content",
        "wordpress-install-dir": ".wp/wordpress"
    }
}
